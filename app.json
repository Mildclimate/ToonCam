{
  "expo": {
    "name": "ToonCam",
    "slug": "tooncam",
    "scheme": "tooncam",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "ToonCam needs access to your camera to render the live cartoon preview."
      },
      "bundleIdentifier": "com.anonymous.tooncam"
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.CAMERA"
      ],
      "package": "com.anonymous.tooncam"
    },
    "assetBundlePatterns": [
      "**/*"
    ]
  }
}
